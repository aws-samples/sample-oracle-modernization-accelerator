# Oracle Database Configuration
ORACLE_SVC_USER=your_username
ORACLE_SVC_PASSWORD=your_password
ORACLE_SVC_CONNECT_STRING=host:port:sid

# PostgreSQL Database Configuration
PGUSER=your_username
PGPASSWORD=your_password
PGHOST=localhost
PGPORT=5432
PGDATABASE=your_database

# MySQL Database Configuration
MYSQL_USER=your_username
MYSQL_PASSWORD=your_password
MYSQL_HOST=localhost
MYSQL_TCP_PORT=3306
MYSQL_DATABASE=your_database

# Agent Configuration
MAX_RETRIES=3
MIN_CONFIDENCE_THRESHOLD=0.7
ACCEPTABLE_PASS_RATE=0.95
COMPARISON_TIMEOUT_SECONDS=30
BATCH_SIZE=10
CONNECTION_POOL_SIZE=5
QUERY_TIMEOUT_SECONDS=60

# LLM Configuration
LLM_PROVIDER=anthropic  # or openai
ANTHROPIC_API_KEY=your_api_key
OPENAI_API_KEY=your_api_key
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# File Paths
MAPPER_DIRECTORY=../bin/test/mappers
PARAMETERS_FILE=../bin/test/parameters.properties
SQL_TRANSFORMER_PATH=../bin/application

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/agent.log
LOG_INCLUDE_SQL=true
LOG_INCLUDE_BIND_VARIABLES=false

# Report Configuration
REPORT_OUTPUT_DIRECTORY=./reports
REPORT_FORMAT=json,html
REPORT_INCLUDE_TRANSFORMATION_HISTORY=true
