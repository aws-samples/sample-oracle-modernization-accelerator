{
  "name": "oma-agent",
  "description": "Oracle Modernization Accelerator agent with MCP servers for database migration",
  "prompt": null,
  "mcpServers": {
    "pg-client-mcp": {
      "type": "stdio",
      "command": "java",
      "args": [
        "-jar",
        "/opt/mcp/pg-client-mcp/target/postgresql-mcp-server-1.0.0.jar",
        "--spring.config.location=/opt/mcp/pg-client-mcp/application-secretsmanager.properties"
      ],
      "timeout": 300000,
      "disabled": false
    },
    "oracle-client-mcp": {
      "type": "stdio",
      "command": "java",
      "args": [
        "-jar",
        "/opt/mcp/oracle-client-mcp/target/oracle-mcp-server-1.0.0.jar",
        "--spring.config.location=/opt/mcp/oracle-client-mcp/application-secretsmanager.properties"
      ],
      "timeout": 300000,
      "disabled": false
    },
    "oma-mcp": {
      "type": "stdio",
      "command": "java",
      "args": [
        "-jar",
        "/opt/mcp/oma-mcp/target/oma-mcp-server-1.0.0.jar",
        "--spring.config.location=/opt/mcp/oma-mcp/application-s3.properties"
      ],
      "timeout": 300000,
      "disabled": false
    }
  },
  "tools": [
    "read",
    "write",
    "shell",
    "aws",
    "report",
    "introspect",
    "knowledge",
    "thinking",
    "todo",
    "delegate",
    "@pg-client-mcp",
    "@oracle-client-mcp",
    "@oma-mcp"
  ],
  "toolAliases": {},
  "allowedTools": [
    "read",
    "write",
    "shell",
    "aws",
    "report",
    "introspect",
    "knowledge",
    "thinking",
    "todo",
    "delegate",
    "@pg-client-mcp",
    "@oracle-client-mcp",
    "@oma-mcp"
  ],
  "resources": [],
  "hooks": {},
  "toolsSettings": {},
  "useLegacyMcpJson": true,
  "model": null
}
