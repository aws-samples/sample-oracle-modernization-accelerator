{
  "name": "mma-agent",
  "description": "Agent with all MMA MCP servers for database migration operations",
  "prompt": null,
  "mcpServers": {
    "pg-client-mcp": {
      "type": "stdio",
      "command": "java",
      "args": [
        "-jar",
        "~/pg-client-mcp/target/postgresql-mcp-server-1.0.0.jar",
        "--spring.config.location=~/pg-client-mcp/application-secretsmanager.properties"
      ],
      "timeout": 300000,
      "disabled": false
    },
    "oracle-client-mcp": {
      "type": "stdio",
      "command": "java",
      "args": [
        "-jar",
        "~/oracle-client-mcp/target/oracle-mcp-server-1.0.0.jar",
        "--spring.config.location=/~/oracle-client-mcp/application-secretsmanager.properties"
      ],
      "timeout": 300000,
      "disabled": false
    },
    "mma-sc-mcp": {
      "type": "stdio",
      "command": "java",
      "args": [
        "-jar",
        "~/dma-sc-mcp/target/mma-sc-mcp-server-1.0.0.jar",
        "--spring.config.location=~/dma-sc-mcp/application-s3.properties"
      ],
      "timeout": 300000,
      "disabled": false
    }
  },
  "tools": [
    "read",
    "write",
    "shell",
    "aws",
    "report",
    "introspect",
    "knowledge",
    "thinking",
    "todo",
    "delegate",
    "@pg-client-mcp",
    "@oracle-client-mcp",
    "@mma-sc-mcp"
  ],
  "toolAliases": {},
  "allowedTools": [    
    "read",
    "write",
    "shell",
    "aws",
    "report",
    "introspect",
    "knowledge",
    "thinking",
    "todo",
    "delegate",
    "@pg-client-mcp",
    "@oracle-client-mcp",
    "@mma-sc-mcp"
  ],
  "resources": [
    "file://AGENTS.md",
    "file://README.md"
  ],
  "hooks": {},
  "toolsSettings": {},
  "useLegacyMcpJson": true,
  "model": null
}