{
  "$schema": "https://raw.githubusercontent.com/aws/amazon-q-developer-cli/refs/heads/main/schemas/agent-v1.json",
  "name": "mma-agent",
  "description": "Agent with all MMA MCP servers for database migration operations",
  "mcpServers": {
    "pg-client-mcp": {
      "type": "stdio",
      "command": "java",
      "args": [
        "-jar",
        "/workshop/MMA-Samples/pg-client-mcp/target/postgresql-mcp-server-1.0.0.jar",
        "--spring.config.location=/workshop/MMA-Samples/pg-client-mcp/application-secretsmanager.properties"
      ],
      "timeout": 300000,
      "disabled": false
    },
    "oracle-client-mcp": {
      "type": "stdio",
      "command": "java",
      "args": [
        "-jar",
        "/workshop/MMA-Samples/oracle-client-mcp/target/oracle-mcp-server-1.0.0.jar",
        "--spring.config.location=/workshop/MMA-Samples/oracle-client-mcp/application-secretsmanager.properties"
      ],
      "timeout": 300000,
      "disabled": false
    },
    "mma-sc-mcp": {
      "type": "stdio",
      "command": "java",
      "args": [
        "-jar",
        "/workshop/MMA-Samples/mma-sc-mcp/target/mma-sc-mcp-server-1.0.0.jar",
        "--spring.config.location=/workshop/MMA-Samples/mma-sc-mcp/application-s3.properties"
      ],
      "timeout": 300000,
      "disabled": false
    }
  },
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "use_aws",
    "gh_issue",
    "knowledge",
    "thinking",
    "todo_list",
    "@pg-client-mcp",
    "@oracle-client-mcp",
    "@mma-sc-mcp"
  ],
  "toolAliases": {},
  "allowedTools": [],
  "resources": [
    "file://AmazonQ.md",
    "file://AGENTS.md",
    "file://README.md",
    "file://.amazonq/rules/**/*.md"
  ],
  "hooks": {},
  "toolsSettings": {},
  "useLegacyMcpJson": true,
  "model": null
}
